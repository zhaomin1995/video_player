<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>zh-Hans</string>
		<string>zh-Hant</string>
		<string>yue</string>
		<string>ja</string>
		<string>ko</string>
		<string>es</string>
		<string>fr</string>
		<string>de</string>
		<string>pt-BR</string>
		<string>ru</string>
	</array>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Awesome Player</string>
	<key>CFBundleDisplayName</key>
	<string>Awesome Player</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<!-- Single source of truth: both come from pbxproj build settings
	     (MARKETING_VERSION + CURRENT_PROJECT_VERSION). Don't hardcode here. -->
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- ATS hardening rationale (was NSAllowsArbitraryLoads=true before):
		     - Control-plane traffic (UpdateChecker, OpenSubtitlesService) uses
		       URLSession and is HTTPS-only by intent. Dropping the global
		       arbitrary-loads switch enforces that.
		     - Media-plane traffic can legitimately be plain HTTP (user pastes
		       an http:// IPTV/HLS link). NSAllowsArbitraryLoadsInMedia keeps
		       AVPlayer working with cleartext media without re-opening every
		       URLSession.
		     - DLNA/Chromecast HTTP serve runs on the LAN — NSAllowsLocalNetworking. -->
		<key>NSAllowsArbitraryLoadsInMedia</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Awesome Player needs local network access to discover and cast to Chromecast, DLNA, and AirPlay devices.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_googlecast._tcp</string>
		<string>_airplay._tcp</string>
	</array>
	<key>CFBundleIconFile</key>
	<string>AppIcon</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2025 Awesome Player. All rights reserved.
xzm01234@gmail.com</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>Awesome Player URL</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>awesomeplayer</string>
			</array>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
		</dict>
	</array>
	<!-- macOS Services menu entry. Right-click any URL in Safari/Chrome (or
	     any selected text that looks like a URL in any app) → Services →
	     "Play in Awesome Player". Also surfaces in Finder for selected files.
	     The Services system invokes our handleServicesURL: on AppDelegate. -->
	<key>NSServices</key>
	<array>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Play in Awesome Player</string>
			</dict>
			<key>NSMessage</key>
			<string>handleServicesURL</string>
			<key>NSPortName</key>
			<string>Awesome Player</string>
			<key>NSSendTypes</key>
			<array>
				<string>public.url</string>
				<string>public.utf8-plain-text</string>
				<string>public.file-url</string>
			</array>
		</dict>
	</array>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Video File</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.movie</string>
				<string>public.video</string>
				<string>public.audio</string>
				<string>public.mpeg-4</string>
				<string>com.apple.quicktime-movie</string>
				<string>public.avi</string>
				<string>org.matroska.mkv</string>
				<string>com.microsoft.windows-media-wmv</string>
				<string>org.webmproject.webm</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
