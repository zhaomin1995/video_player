    "Casting Dolby Vision isn't supported. Play locally instead.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Streamen von Dolby Vision wird nicht unterstützt. Bitte stattdessen lokal abspielen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se admite la transmisión de Dolby Vision. Reproduce localmente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La diffusion Dolby Vision n'est pas prise en charge. Lisez localement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Dolby Vision のキャストは未対応です。ローカルで再生してください。"
