    "Streaming is not implemented yet. Use Save as File to transcode to disk.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "流式输出尚未实现,请使用「保存为文件」将其转码到磁盘。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "串流輸出尚未實作,請使用「儲存為檔案」轉碼到磁碟。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ストリーミング機能は未実装です。「ファイルに保存」を使用してディスクに変換してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스트리밍은 아직 구현되지 않았습니다. '파일로 저장'으로 디스크에 트랜스코딩하세요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La transmisión aún no está implementada. Usa Guardar como archivo para transcodificar a disco."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La diffusion n'est pas encore implémentée. Utilisez Enregistrer dans un fichier."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Streaming ist noch nicht implementiert. Verwenden Sie „Als Datei sichern“, um auf die Festplatte zu transkodieren."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A transmissão ainda não foi implementada. Use Salvar como arquivo para transcodificar para o disco."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Потоковая трансляция ещё не реализована. Используйте «Сохранить в файл» для перекодирования на диск."
          }
        }
      }
    },
