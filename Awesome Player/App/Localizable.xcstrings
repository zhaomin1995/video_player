    "Awesome Player needs to relaunch for the language change to take effect.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语言更改需要重启 Awesome Player 才能生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "語言變更需要重新啟動 Awesome Player 才會生效。"
          }
        },
        "yue": {
          "stringUnit": {
            "state": "translated",
            "value": "語言變更需要重新啟動 Awesome Player 先會生效。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "言語の変更を反映するには Awesome Player を再起動する必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "언어 변경 사항을 적용하려면 Awesome Player를 다시 시작해야 합니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Awesome Player debe reiniciarse para aplicar el cambio de idioma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Awesome Player doit redémarrer pour appliquer le changement de langue."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Awesome Player muss neu gestartet werden, damit die Sprachänderung wirksam wird."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Awesome Player precisa ser reiniciado para aplicar a alteração de idioma."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Awesome Player необходимо перезапустить, чтобы изменения языка вступили в силу."
          }
        }
      }
    },
    "Relaunch Now": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
