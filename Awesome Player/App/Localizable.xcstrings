    "libvlc reported an error during transcoding. The profile may be incompatible with the source codec.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "libvlc 在转码过程中报告了错误。该配置文件可能与源编解码器不兼容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "libvlc 在轉碼過程中回報了錯誤。該設定檔可能與來源編解碼器不相容。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "libvlc がトランスコード中にエラーを報告しました。プロファイルはソースコーデックと互換性がない可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "libvlc가 트랜스코딩 중 오류를 보고했습니다. 프로파일이 소스 코덱과 호환되지 않을 수 있습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "libvlc informó de un error durante la transcodificación. El perfil puede ser incompatible con el códec de origen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "libvlc a signalé une erreur lors du transcodage. Le profil peut être incompatible avec le codec source."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "libvlc meldete einen Fehler beim Transkodieren. Das Profil ist möglicherweise mit dem Quellcodec inkompatibel."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O libvlc relatou um erro durante a transcodificação. O perfil pode ser incompatível com o codec de origem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "libvlc сообщил об ошибке при перекодировании. Профиль может быть несовместим с исходным кодеком."
          }
        },
        "yue": {
          "stringUnit": {
            "state": "translated",
            "value": "libvlc 喺轉碼過程中報告咗錯誤。呢個設定檔可能同來源編解碼器唔兼容。"
          }
        }
      }
    },
