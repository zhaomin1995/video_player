        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Dolby Vision 캐스트는 지원되지 않습니다. 로컬에서 재생하십시오."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A transmissão em Dolby Vision não é compatível. Reproduza localmente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Трансляция Dolby Vision не поддерживается. Воспроизведите локально."
          }
        },
        "yue": {
          "stringUnit": {
            "state": "translated",
            "value": "唔支援投放 Dolby Vision，請喺本機播放。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不支持投屏 Dolby Vision，请在本机播放。"
          }
        },
