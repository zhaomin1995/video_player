    "Use Apple VideoToolbox for H.264/HEVC profiles. Falls back to software for other codecs.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple VideoToolbox für H.264-/HEVC-Profile verwenden. Bei anderen Codecs wird auf Software zurückgegriffen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa Apple VideoToolbox para perfiles H.264/HEVC. Recurre a software para otros códecs."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilise Apple VideoToolbox pour les profils H.264/HEVC. Bascule sur logiciel pour les autres codecs."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "H.264/HEVC プロファイルに Apple VideoToolbox を使用します。その他のコーデックではソフトウェアにフォールバックします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "H.264/HEVC 프로파일에 Apple VideoToolbox를 사용합니다. 다른 코덱은 소프트웨어로 대체됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa o Apple VideoToolbox para perfis H.264/HEVC. Recorre a software para outros codecs."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Использует Apple VideoToolbox для профилей H.264/HEVC. Для других кодеков — программный кодировщик."
          }
        },
        "yue": {
          "stringUnit": {
            "state": "translated",
            "value": "對 H.264/HEVC 設定檔使用 Apple VideoToolbox。其他編碼器會退回軟件處理。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对 H.264/HEVC 配置文件使用 Apple VideoToolbox。其他编解码器回退到软件处理。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "對 H.264/HEVC 設定檔使用 Apple VideoToolbox。其他編碼器會退回軟件處理。"
          }
        }
      }
    },
